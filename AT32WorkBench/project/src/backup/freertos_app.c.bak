/**
  * @brief  initializes all task.
  * @param  none
  * @retval none
  */
void freertos_task_create(void)
{
  /* create MC_Task task */
  xTaskCreate(MC_Task_func,
              "MC_Task",
              512,
              NULL,
              3,
              &MC_Task_handle);

  /* create CANCom_Task task */
  xTaskCreate(CANCom_Task_func,
              "CANCom_Task",
              512,
              NULL,
              2,
              &CANCom_Task_handle);

  /* create Monitor_Task task */
  xTaskCreate(Monitor_Task_func,
              "Monitor_Task",
              512,
              NULL,
              1,
              &Monitor_Task_handle);

  /* create Debug_Task task */
  xTaskCreate(Debug_Task_func,
              "Debug_Task",
              512,
              NULL,
              0,
              &Debug_Task_handle);
}

/**
  * @brief  freertos init and begin run.
  * @param  none
  * @retval none
  */
void wk_freertos_init(void)
{
  /* add user code begin freertos_init 0 */

  /* add user code end freertos_init 0 */

  /* enter critical */
  taskENTER_CRITICAL();

  freertos_task_create();
	
  /* add user code begin freertos_init 1 */

  /* add user code end freertos_init 1 */

  /* exit critical */
  taskEXIT_CRITICAL();

  /* start scheduler */
  vTaskStartScheduler();
}

/**
  * @brief MC_Task function.
  * @param  none
  * @retval none
  */
void MC_Task_func(void *pvParameters)
{
  /* add user code begin MC_Task_func 0 */
  /* 简单的电机驱动程序，不使用FOC算法 */
  uint16_t pwm_duty = 750; // 适中的占空比
  uint8_t phase = 0; // 相位

  /* add user code end MC_Task_func 0 */

  /* add user code begin MC_Task_func 2 */

  /* add user code end MC_Task_func 2 */

  /* Infinite loop */
  while(1)
  {
    /* when use usb,the function wk_usb_app_task() will be generated,
       which is the usb application layer code that users can improve themselves */
    wk_usb_app_task();

  /* add user code begin MC_Task_func 1 */
    /* 简单的三相PWM驱动，产生旋转磁场 - 使用标准6步换向序列 */
    switch(phase) {
      case 0:
        // U相高，V相低，W相低
        tmr_channel_value_set(TMR1, TMR_SELECT_CHANNEL_1, pwm_duty);
        tmr_channel_value_set(TMR1, TMR_SELECT_CHANNEL_2, 0);
        tmr_channel_value_set(TMR1, TMR_SELECT_CHANNEL_3, 0);
        break;
      case 1:
        // U相高，V相高，W相低
        tmr_channel_value_set(TMR1, TMR_SELECT_CHANNEL_1, pwm_duty);
        tmr_channel_value_set(TMR1, TMR_SELECT_CHANNEL_2, pwm_duty);
        tmr_channel_value_set(TMR1, TMR_SELECT_CHANNEL_3, 0);
        break;
      case 2:
        // U相低，V相高，W相低
        tmr_channel_value_set(TMR1, TMR_SELECT_CHANNEL_1, 0);
        tmr_channel_value_set(TMR1, TMR_SELECT_CHANNEL_2, pwm_duty);
        tmr_channel_value_set(TMR1, TMR_SELECT_CHANNEL_3, 0);
        break;
      case 3:
        // U相低，V相高，W相高
        tmr_channel_value_set(TMR1, TMR_SELECT_CHANNEL_1, 0);
        tmr_channel_value_set(TMR1, TMR_SELECT_CHANNEL_2, pwm_duty);
        tmr_channel_value_set(TMR1, TMR_SELECT_CHANNEL_3, pwm_duty);
        break;
      case 4:
        // U相低，V相低，W相高
        tmr_channel_value_set(TMR1, TMR_SELECT_CHANNEL_1, 0);
        tmr_channel_value_set(TMR1, TMR_SELECT_CHANNEL_2, 0);
        tmr_channel_value_set(TMR1, TMR_SELECT_CHANNEL_3, pwm_duty);
        break;
      case 5:
        // U相高，V相低，W相高
        tmr_channel_value_set(TMR1, TMR_SELECT_CHANNEL_1, pwm_duty);
        tmr_channel_value_set(TMR1, TMR_SELECT_CHANNEL_2, 0);
        tmr_channel_value_set(TMR1, TMR_SELECT_CHANNEL_3, pwm_duty);
        break;
    }
    
    // 递增相位，产生旋转磁场
    phase = (phase + 1) % 6;
    
    // 控制转速，增加延迟时间，降低换向频率
    vTaskDelay(5);

  /* add user code end MC_Task_func 1 */
  }
}


