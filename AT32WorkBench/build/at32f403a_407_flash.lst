 943:libraries/drivers/src/at32f403a_407_flash.c **** /**
 944:libraries/drivers/src/at32f403a_407_flash.c ****   * @brief  program the flash system setting byte in usd: wdt_ato_en / depslp_rst / stdby_rst / bto
 945:libraries/drivers/src/at32f403a_407_flash.c ****   * @param  usd_ssb: the system setting byte
 946:libraries/drivers/src/at32f403a_407_flash.c ****   * @note   this parameter usd_ssb must contain a combination of all the following 4 types of data
 947:libraries/drivers/src/at32f403a_407_flash.c ****   *         type 1: wdt_ato_en, select the wdt auto start
 948:libraries/drivers/src/at32f403a_407_flash.c ****   *         this data can be one of the following values:
 949:libraries/drivers/src/at32f403a_407_flash.c ****   *         - USD_WDT_ATO_DISABLE: disable wdt auto start
 950:libraries/drivers/src/at32f403a_407_flash.c ****   *         - USD_WDT_ATO_ENABLE: enable wdt auto start
 951:libraries/drivers/src/at32f403a_407_flash.c ****   *         type 2: depslp_rst, reset event when entering deepsleep mode.
 952:libraries/drivers/src/at32f403a_407_flash.c ****   *         this data can be one of the following values:
 953:libraries/drivers/src/at32f403a_407_flash.c ****   *         - USD_DEPSLP_NO_RST: no reset generated when entering in deepsleep
 954:libraries/drivers/src/at32f403a_407_flash.c ****   *         - USD_DEPSLP_RST: reset generated when entering in deepsleep
 955:libraries/drivers/src/at32f403a_407_flash.c ****   *         type 3: stdby_rst, reset event when entering standby mode.
 956:libraries/drivers/src/at32f403a_407_flash.c ****   *         this data can be one of the following values:
 957:libraries/drivers/src/at32f403a_407_flash.c ****   *         - USD_STDBY_NO_RST: no reset generated when entering in standby
 958:libraries/drivers/src/at32f403a_407_flash.c ****   *         - USD_STDBY_RST: reset generated when entering in standby
 959:libraries/drivers/src/at32f403a_407_flash.c ****   *         type 4: btopt, at startup,if boot pins are set in boot from user flash position,selecte
 960:libraries/drivers/src/at32f403a_407_flash.c ****   *         this data can be one of the following values:
 961:libraries/drivers/src/at32f403a_407_flash.c ****   *         - FLASH_BOOT_FROM_BANK1:boot from bank1
 962:libraries/drivers/src/at32f403a_407_flash.c ****   *         - FLASH_BOOT_FROM_BANK2:boot from bank 2 or bank 1
ARM GAS  C:\Users\10963\AppData\Local\Temp\cceVuDrX.s 			page 52


