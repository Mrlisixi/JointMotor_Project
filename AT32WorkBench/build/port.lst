 191:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****     /* Simulate the stack frame as it would be created by a context switch
 192:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****      * interrupt. */
 193:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c **** 
 194:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****     /* Offset added to account for the way the MCU uses the stack on entry/exit
 195:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****      * of interrupts, and to ensure alignment. */
 196:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****     pxTopOfStack--;
 197:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c **** 
 198:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****     *pxTopOfStack = portINITIAL_XPSR;                                    /* xPSR */
 199:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****     pxTopOfStack--;
 200:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****     *pxTopOfStack = ( ( StackType_t ) pxCode ) & portSTART_ADDRESS_MASK; /* PC */
 201:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****     pxTopOfStack--;
 202:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****     *pxTopOfStack = ( StackType_t ) portTASK_RETURN_ADDRESS;             /* LR */
