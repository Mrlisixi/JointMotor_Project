 203:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c **** 
 204:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****     /* Save code space by skipping register initialisation. */
 205:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****     pxTopOfStack -= 5;                            /* R12, R3, R2 and R1. */
 206:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****     *pxTopOfStack = ( StackType_t ) pvParameters; /* R0 */
 207:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c **** 
 208:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****     /* A save method is being used that requires each task to maintain its
 209:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****      * own exec return value. */
 210:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****     pxTopOfStack--;
 211:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****     *pxTopOfStack = portINITIAL_EXC_RETURN;
 212:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c **** 
 213:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****     pxTopOfStack -= 8; /* R11, R10, R9, R8, R7, R6, R5 and R4. */
 214:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c **** 
 215:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****     return pxTopOfStack;
 216:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c **** }
