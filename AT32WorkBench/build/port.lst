 766:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c **** 
 767:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****         /* Priority grouping:  The interrupt controller (NVIC) allows the bits
 768:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****          * that define each interrupt's priority to be split between bits that
 769:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****          * define the interrupt's pre-emption priority bits and bits that define
 770:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****          * the interrupt's sub-priority.  For simplicity all bits must be defined
 771:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****          * to be pre-emption priority bits.  The following assertion will fail if
 772:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****          * this is not the case (if some bits represent a sub-priority).
 773:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****          *
 774:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****          * If the application only uses CMSIS libraries for interrupt
 775:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****          * configuration then the correct setting can be achieved on all Cortex-M
 776:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****          * devices by calling NVIC_SetPriorityGrouping( 0 ); before starting the
 777:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****          * scheduler.  Note however that some vendor specific peripheral libraries
 778:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****          * assume a non-zero priority group setting, in which cases using a value
 779:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****          * of zero will result in unpredictable behaviour. */
 780:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****         configASSERT( ( portAIRCR_REG & portPRIORITY_GROUP_MASK ) <= ulMaxPRIGROUPValue );
