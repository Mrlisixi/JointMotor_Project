 740:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c **** 
 741:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****             /* The following assertion will fail if a service routine (ISR) for
 742:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****              * an interrupt that has been assigned a priority above
 743:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****              * configMAX_SYSCALL_INTERRUPT_PRIORITY calls an ISR safe FreeRTOS API
 744:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****              * function.  ISR safe FreeRTOS API functions must *only* be called
 745:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****              * from interrupts that have been assigned a priority at or below
 746:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****              * configMAX_SYSCALL_INTERRUPT_PRIORITY.
 747:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****              *
 748:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****              * Numerically low interrupt priority numbers represent logically high
 749:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****              * interrupt priorities, therefore the priority of the interrupt must
 750:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****              * be set to a value equal to or numerically *higher* than
 751:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****              * configMAX_SYSCALL_INTERRUPT_PRIORITY.
 752:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****              *
 753:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****              * Interrupts that	use the FreeRTOS API must not be left at their
 754:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****              * default priority of	zero as that is the highest possible priority,
 755:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****              * which is guaranteed to be above configMAX_SYSCALL_INTERRUPT_PRIORITY,
 756:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****              * and	therefore also guaranteed to be invalid.
 757:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****              *
 758:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****              * FreeRTOS maintains separate thread and ISR API functions to ensure
 759:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****              * interrupt entry is as fast and simple as possible.
 760:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****              *
 761:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****              * The following links provide detailed information:
 762:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****              * https://www.FreeRTOS.org/RTOS-Cortex-M3-M4.html
 763:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****              * https://www.FreeRTOS.org/FAQHelp.html */
 764:middlewares/freertos/source/portable/GCC/ARM_CM4F/port.c ****             configASSERT( ucCurrentPriority >= ucMaxSysCallPriority );
