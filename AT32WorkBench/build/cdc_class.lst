ARM GAS  C:\Users\10963\AppData\Local\Temp\cc0PXrIj.s 			page 4


 145:project/src/cdc_class.c **** static usb_sts_type class_setup_handler(void *udev, usb_setup_type *setup)
 146:project/src/cdc_class.c **** {
 147:project/src/cdc_class.c ****   usb_sts_type status = USB_OK;
 148:project/src/cdc_class.c ****   usbd_core_type *pudev = (usbd_core_type *)udev;
 149:project/src/cdc_class.c ****   cdc_struct_type *pcdc = (cdc_struct_type *)pudev->class_handler->pdata;
 150:project/src/cdc_class.c **** 
 151:project/src/cdc_class.c ****   switch(setup->bmRequestType & USB_REQ_TYPE_RESERVED)
 152:project/src/cdc_class.c ****   {
 153:project/src/cdc_class.c ****     /* class request */
 154:project/src/cdc_class.c ****     case USB_REQ_TYPE_CLASS:
 155:project/src/cdc_class.c ****       if(setup->wLength)
 156:project/src/cdc_class.c ****       {
 157:project/src/cdc_class.c ****         if(setup->bmRequestType & USB_REQ_DIR_DTH)
 158:project/src/cdc_class.c ****         {
 159:project/src/cdc_class.c ****           usb_vcp_cmd_process(udev, setup->bRequest, pcdc->g_cmd, setup->wLength);
 160:project/src/cdc_class.c ****           usbd_ctrl_send(pudev, pcdc->g_cmd, setup->wLength);
 161:project/src/cdc_class.c ****         }
 162:project/src/cdc_class.c ****         else
 163:project/src/cdc_class.c ****         {
 164:project/src/cdc_class.c ****           pcdc->g_req = setup->bRequest;
 165:project/src/cdc_class.c ****           pcdc->g_len = setup->wLength;
 166:project/src/cdc_class.c ****           usbd_ctrl_recv(pudev, pcdc->g_cmd, pcdc->g_len);
 167:project/src/cdc_class.c **** 
 168:project/src/cdc_class.c ****         }
 169:project/src/cdc_class.c ****       }
 170:project/src/cdc_class.c ****       break;
 171:project/src/cdc_class.c ****     /* standard request */
 172:project/src/cdc_class.c ****     case USB_REQ_TYPE_STANDARD:
 173:project/src/cdc_class.c ****       switch(setup->bRequest)
 174:project/src/cdc_class.c ****       {
 175:project/src/cdc_class.c ****         case USB_STD_REQ_GET_DESCRIPTOR:
 176:project/src/cdc_class.c ****           usbd_ctrl_unsupport(pudev);
 177:project/src/cdc_class.c ****           break;
 178:project/src/cdc_class.c ****         case USB_STD_REQ_GET_INTERFACE:
 179:project/src/cdc_class.c ****           usbd_ctrl_send(pudev, (uint8_t *)&pcdc->alt_setting, 1);
 180:project/src/cdc_class.c ****           break;
 181:project/src/cdc_class.c ****         case USB_STD_REQ_SET_INTERFACE:
 182:project/src/cdc_class.c ****           pcdc->alt_setting = setup->wValue;
 183:project/src/cdc_class.c ****           break;
 184:project/src/cdc_class.c ****         case USB_STD_REQ_CLEAR_FEATURE:
 185:project/src/cdc_class.c ****           break;
 186:project/src/cdc_class.c ****         case USB_STD_REQ_SET_FEATURE:
 187:project/src/cdc_class.c ****           break;
 188:project/src/cdc_class.c ****         default:
 189:project/src/cdc_class.c ****           usbd_ctrl_unsupport(pudev);
 190:project/src/cdc_class.c ****           break;
 191:project/src/cdc_class.c ****       }
 192:project/src/cdc_class.c ****       break;
 193:project/src/cdc_class.c ****     default:
 194:project/src/cdc_class.c ****       usbd_ctrl_unsupport(pudev);
 195:project/src/cdc_class.c ****       break;
 196:project/src/cdc_class.c ****   }
 197:project/src/cdc_class.c ****   return status;
 198:project/src/cdc_class.c **** }
