 344:project/src/cdc_class.c **** uint16_t usb_vcp_get_rxdata(void *udev, uint8_t *recv_data)
 345:project/src/cdc_class.c **** {
 346:project/src/cdc_class.c ****   uint16_t i_index = 0;
 347:project/src/cdc_class.c ****   uint16_t tmp_len = 0;
 348:project/src/cdc_class.c ****   usbd_core_type *pudev = (usbd_core_type *)udev;
 349:project/src/cdc_class.c ****   cdc_struct_type *pcdc = (cdc_struct_type *)pudev->class_handler->pdata;
 350:project/src/cdc_class.c **** 
 351:project/src/cdc_class.c ****   if(pcdc->g_rx_completed == 0)
 352:project/src/cdc_class.c ****   {
 353:project/src/cdc_class.c ****     return 0;
 354:project/src/cdc_class.c ****   }
