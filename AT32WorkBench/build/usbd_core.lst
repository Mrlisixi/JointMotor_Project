  80:middlewares/usbd_drivers/src/usbd_core.c **** 
  81:middlewares/usbd_drivers/src/usbd_core.c ****       }
  82:middlewares/usbd_drivers/src/usbd_core.c ****     }
  83:middlewares/usbd_drivers/src/usbd_core.c ****   }
  84:middlewares/usbd_drivers/src/usbd_core.c ****   else if(udev->class_handler->in_handler != 0 &&
  85:middlewares/usbd_drivers/src/usbd_core.c ****           udev->conn_state == USB_CONN_STATE_CONFIGURED)
  86:middlewares/usbd_drivers/src/usbd_core.c ****   {
