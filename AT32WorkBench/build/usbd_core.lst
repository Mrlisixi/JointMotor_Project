  51:middlewares/usbd_drivers/src/usbd_core.c **** 
  52:middlewares/usbd_drivers/src/usbd_core.c ****   if(ept_addr == 0)
  53:middlewares/usbd_drivers/src/usbd_core.c ****   {
  54:middlewares/usbd_drivers/src/usbd_core.c ****     if(udev->ept0_sts == USB_EPT0_DATA_IN)
  55:middlewares/usbd_drivers/src/usbd_core.c ****     {
  56:middlewares/usbd_drivers/src/usbd_core.c ****       if(ept_info->rem0_len > ept_info->maxpacket)
  57:middlewares/usbd_drivers/src/usbd_core.c ****       {
  58:middlewares/usbd_drivers/src/usbd_core.c ****         ept_info->rem0_len -= ept_info->maxpacket;
  59:middlewares/usbd_drivers/src/usbd_core.c ****         usbd_ept_send(udev, 0, ept_info->trans_buf,
  60:middlewares/usbd_drivers/src/usbd_core.c ****                       MIN(ept_info->rem0_len, ept_info->maxpacket));
  61:middlewares/usbd_drivers/src/usbd_core.c ****       }
  62:middlewares/usbd_drivers/src/usbd_core.c ****       /* endpoint 0 */
  63:middlewares/usbd_drivers/src/usbd_core.c ****       else if(ept_info->last_len == ept_info->maxpacket
  64:middlewares/usbd_drivers/src/usbd_core.c ****         && ept_info->ept0_slen >= ept_info->maxpacket
  65:middlewares/usbd_drivers/src/usbd_core.c ****         && ept_info->ept0_slen < udev->ept0_wlength)
  66:middlewares/usbd_drivers/src/usbd_core.c ****       {
  67:middlewares/usbd_drivers/src/usbd_core.c ****         ept_info->last_len = 0;
  68:middlewares/usbd_drivers/src/usbd_core.c ****         usbd_ept_send(udev, 0, 0, 0);
  69:middlewares/usbd_drivers/src/usbd_core.c ****         usbd_ept_recv(udev, ept_addr, 0, 0);
  70:middlewares/usbd_drivers/src/usbd_core.c ****       }
  71:middlewares/usbd_drivers/src/usbd_core.c ****       else
  72:middlewares/usbd_drivers/src/usbd_core.c ****       {
  73:middlewares/usbd_drivers/src/usbd_core.c **** 
  74:middlewares/usbd_drivers/src/usbd_core.c ****         if(udev->class_handler->ept0_tx_handler != 0 &&
  75:middlewares/usbd_drivers/src/usbd_core.c ****             udev->conn_state == USB_CONN_STATE_CONFIGURED)
  76:middlewares/usbd_drivers/src/usbd_core.c ****         {
  77:middlewares/usbd_drivers/src/usbd_core.c ****           udev->class_handler->ept0_tx_handler(udev);
  78:middlewares/usbd_drivers/src/usbd_core.c ****         }
