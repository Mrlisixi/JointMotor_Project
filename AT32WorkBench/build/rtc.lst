  43:project/src/rtc.c **** /**
  44:project/src/rtc.c ****   * @brief  rtc peripheral initialization.
  45:project/src/rtc.c ****   * @param  calendar
  46:project/src/rtc.c ****   * @retval 0: rtc already init
  47:project/src/rtc.c ****             1: rtc init
  48:project/src/rtc.c ****   */
  49:project/src/rtc.c **** uint8_t rtc_init(calendar_type *calendar)
  50:project/src/rtc.c **** {
  51:project/src/rtc.c ****   /* enable pwc and bpr clocks */
  52:project/src/rtc.c ****   crm_periph_clock_enable(CRM_PWC_PERIPH_CLOCK, TRUE);
  53:project/src/rtc.c ****   crm_periph_clock_enable(CRM_BPR_PERIPH_CLOCK, TRUE);
  54:project/src/rtc.c **** 
  55:project/src/rtc.c ****   /* enable the battery-powered domain write operations */
  56:project/src/rtc.c ****   pwc_battery_powered_domain_access(TRUE);
  57:project/src/rtc.c **** 
  58:project/src/rtc.c ****   /* check if rtc is initialized */
  59:project/src/rtc.c ****   if(bpr_data_read(BPR_DATA1) != 0x1234)
  60:project/src/rtc.c ****   {
  61:project/src/rtc.c ****     /* reset battery-powered domain register */
  62:project/src/rtc.c ****     bpr_reset();
  63:project/src/rtc.c **** 
  64:project/src/rtc.c ****     /* enable the lext osc */
  65:project/src/rtc.c ****     crm_clock_source_enable(CRM_CLOCK_SOURCE_LEXT, TRUE);
  66:project/src/rtc.c ****     /* wait lext is ready */
  67:project/src/rtc.c ****     while(crm_flag_get(CRM_LEXT_STABLE_FLAG) == RESET);
  68:project/src/rtc.c ****     /* select the rtc clock source */
  69:project/src/rtc.c ****     crm_rtc_clock_select(CRM_RTC_CLOCK_LEXT);
  70:project/src/rtc.c **** 
  71:project/src/rtc.c ****     /* enable rtc clock */
  72:project/src/rtc.c ****     crm_rtc_clock_enable(TRUE);
  73:project/src/rtc.c **** 
  74:project/src/rtc.c ****     /* wait for rtc registers update */
  75:project/src/rtc.c ****     rtc_wait_update_finish();
  76:project/src/rtc.c **** 
  77:project/src/rtc.c ****     /* wait for the register write to complete */
  78:project/src/rtc.c ****     rtc_wait_config_finish();
  79:project/src/rtc.c **** 
  80:project/src/rtc.c ****     /* set rtc divider: set rtc period to 1sec */
  81:project/src/rtc.c ****     rtc_divider_set(32767);
  82:project/src/rtc.c **** 
  83:project/src/rtc.c ****     /* wait for the register write to complete */
  84:project/src/rtc.c ****     rtc_wait_config_finish();
  85:project/src/rtc.c **** 
  86:project/src/rtc.c ****     /* set time */
ARM GAS  C:\Users\10963\AppData\Local\Temp\cc6IUeV7.s 			page 3


  87:project/src/rtc.c ****     rtc_time_set(calendar);
  88:project/src/rtc.c **** 
  89:project/src/rtc.c ****     /* writes data to bpr register */
  90:project/src/rtc.c ****     bpr_data_write(BPR_DATA1, 0x1234);
  91:project/src/rtc.c **** 
  92:project/src/rtc.c ****     return 1;
  93:project/src/rtc.c ****   }
  94:project/src/rtc.c ****   else
  95:project/src/rtc.c ****   {
  96:project/src/rtc.c ****     /* wait for rtc registers update */
  97:project/src/rtc.c ****     rtc_wait_update_finish();
  98:project/src/rtc.c **** 
  99:project/src/rtc.c ****     /* wait for the register write to complete */
 100:project/src/rtc.c ****     rtc_wait_config_finish();
 101:project/src/rtc.c **** 
 102:project/src/rtc.c ****     return 0;
 103:project/src/rtc.c ****   }
 104:project/src/rtc.c **** }
