  56:../Common/src/usb_cdc_protocol.c ****       rx_len += recv_len;
  57:../Common/src/usb_cdc_protocol.c ****       printf("Buffer length: %d\r\n", rx_len);
  58:../Common/src/usb_cdc_protocol.c ****     }
