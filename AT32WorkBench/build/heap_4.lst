  93:middlewares/freertos/source/portable/memmang/heap_4.c **** /* The size of the structure placed at the beginning of each allocated memory
  94:middlewares/freertos/source/portable/memmang/heap_4.c ****  * block must by correctly byte aligned. */
  95:middlewares/freertos/source/portable/memmang/heap_4.c **** static const size_t xHeapStructSize = ( sizeof( BlockLink_t ) + ( ( size_t ) ( portBYTE_ALIGNMENT -
  96:middlewares/freertos/source/portable/memmang/heap_4.c **** 
  97:middlewares/freertos/source/portable/memmang/heap_4.c **** /* Create a couple of list links to mark the start and end of the list. */
  98:middlewares/freertos/source/portable/memmang/heap_4.c **** PRIVILEGED_DATA static BlockLink_t xStart, * pxEnd = NULL;
  99:middlewares/freertos/source/portable/memmang/heap_4.c **** 
 100:middlewares/freertos/source/portable/memmang/heap_4.c **** /* Keeps track of the number of calls to allocate and free memory as well as the
 101:middlewares/freertos/source/portable/memmang/heap_4.c ****  * number of free bytes remaining, but says nothing about fragmentation. */
 102:middlewares/freertos/source/portable/memmang/heap_4.c **** PRIVILEGED_DATA static size_t xFreeBytesRemaining = 0U;
 103:middlewares/freertos/source/portable/memmang/heap_4.c **** PRIVILEGED_DATA static size_t xMinimumEverFreeBytesRemaining = 0U;
 104:middlewares/freertos/source/portable/memmang/heap_4.c **** PRIVILEGED_DATA static size_t xNumberOfSuccessfulAllocations = 0;
 105:middlewares/freertos/source/portable/memmang/heap_4.c **** PRIVILEGED_DATA static size_t xNumberOfSuccessfulFrees = 0;
 106:middlewares/freertos/source/portable/memmang/heap_4.c **** 
 107:middlewares/freertos/source/portable/memmang/heap_4.c **** /* Gets set to the top bit of an size_t type.  When this bit in the xBlockSize
 108:middlewares/freertos/source/portable/memmang/heap_4.c ****  * member of an BlockLink_t structure is set then the block belongs to the
 109:middlewares/freertos/source/portable/memmang/heap_4.c ****  * application.  When the bit is free the block is still part of the free heap
 110:middlewares/freertos/source/portable/memmang/heap_4.c ****  * space. */
 111:middlewares/freertos/source/portable/memmang/heap_4.c **** PRIVILEGED_DATA static size_t xBlockAllocatedBit = 0;
 112:middlewares/freertos/source/portable/memmang/heap_4.c **** 
 113:middlewares/freertos/source/portable/memmang/heap_4.c **** /*-----------------------------------------------------------*/
 114:middlewares/freertos/source/portable/memmang/heap_4.c **** 
 115:middlewares/freertos/source/portable/memmang/heap_4.c **** void * pvPortMalloc( size_t xWantedSize )
 116:middlewares/freertos/source/portable/memmang/heap_4.c **** {
 117:middlewares/freertos/source/portable/memmang/heap_4.c ****     BlockLink_t * pxBlock, * pxPreviousBlock, * pxNewBlockLink;
 118:middlewares/freertos/source/portable/memmang/heap_4.c ****     void * pvReturn = NULL;
 119:middlewares/freertos/source/portable/memmang/heap_4.c **** 
 120:middlewares/freertos/source/portable/memmang/heap_4.c ****     vTaskSuspendAll();
 121:middlewares/freertos/source/portable/memmang/heap_4.c ****     {
 122:middlewares/freertos/source/portable/memmang/heap_4.c ****         /* If this is the first call to malloc then the heap will require
 123:middlewares/freertos/source/portable/memmang/heap_4.c ****          * initialisation to setup the list of free blocks. */
 124:middlewares/freertos/source/portable/memmang/heap_4.c ****         if( pxEnd == NULL )
 125:middlewares/freertos/source/portable/memmang/heap_4.c ****         {
 126:middlewares/freertos/source/portable/memmang/heap_4.c ****             prvHeapInit();
 127:middlewares/freertos/source/portable/memmang/heap_4.c ****         }
 128:middlewares/freertos/source/portable/memmang/heap_4.c ****         else
 129:middlewares/freertos/source/portable/memmang/heap_4.c ****         {
 130:middlewares/freertos/source/portable/memmang/heap_4.c ****             mtCOVERAGE_TEST_MARKER();
 131:middlewares/freertos/source/portable/memmang/heap_4.c ****         }
 132:middlewares/freertos/source/portable/memmang/heap_4.c **** 
 133:middlewares/freertos/source/portable/memmang/heap_4.c ****         /* Check the requested block size is not so large that the top bit is
 134:middlewares/freertos/source/portable/memmang/heap_4.c ****          * set.  The top bit of the block size member of the BlockLink_t structure
 135:middlewares/freertos/source/portable/memmang/heap_4.c ****          * is used to determine who owns the block - the application or the
 136:middlewares/freertos/source/portable/memmang/heap_4.c ****          * kernel, so it must be free. */
 137:middlewares/freertos/source/portable/memmang/heap_4.c ****         if( ( xWantedSize & xBlockAllocatedBit ) == 0 )
 138:middlewares/freertos/source/portable/memmang/heap_4.c ****         {
 139:middlewares/freertos/source/portable/memmang/heap_4.c ****             /* The wanted size must be increased so it can contain a BlockLink_t
 140:middlewares/freertos/source/portable/memmang/heap_4.c ****              * structure in addition to the requested amount of bytes. */
 141:middlewares/freertos/source/portable/memmang/heap_4.c ****             if( ( xWantedSize > 0 ) &&
 142:middlewares/freertos/source/portable/memmang/heap_4.c ****                 ( ( xWantedSize + xHeapStructSize ) >  xWantedSize ) ) /* Overflow check */
 143:middlewares/freertos/source/portable/memmang/heap_4.c ****             {
 144:middlewares/freertos/source/portable/memmang/heap_4.c ****                 xWantedSize += xHeapStructSize;
 145:middlewares/freertos/source/portable/memmang/heap_4.c **** 
ARM GAS  C:\Users\10963\AppData\Local\Temp\cclcvN1N.s 			page 4


 146:middlewares/freertos/source/portable/memmang/heap_4.c ****                 /* Ensure that blocks are always aligned. */
 147:middlewares/freertos/source/portable/memmang/heap_4.c ****                 if( ( xWantedSize & portBYTE_ALIGNMENT_MASK ) != 0x00 )
 148:middlewares/freertos/source/portable/memmang/heap_4.c ****                 {
 149:middlewares/freertos/source/portable/memmang/heap_4.c ****                     /* Byte alignment required. Check for overflow. */
 150:middlewares/freertos/source/portable/memmang/heap_4.c ****                     if( ( xWantedSize + ( portBYTE_ALIGNMENT - ( xWantedSize & portBYTE_ALIGNMENT_M
 151:middlewares/freertos/source/portable/memmang/heap_4.c ****                             > xWantedSize )
 152:middlewares/freertos/source/portable/memmang/heap_4.c ****                     {
 153:middlewares/freertos/source/portable/memmang/heap_4.c ****                         xWantedSize += ( portBYTE_ALIGNMENT - ( xWantedSize & portBYTE_ALIGNMENT_MA
 154:middlewares/freertos/source/portable/memmang/heap_4.c ****                         configASSERT( ( xWantedSize & portBYTE_ALIGNMENT_MASK ) == 0 );
 155:middlewares/freertos/source/portable/memmang/heap_4.c ****                     }
 156:middlewares/freertos/source/portable/memmang/heap_4.c ****                     else
 157:middlewares/freertos/source/portable/memmang/heap_4.c ****                     {
 158:middlewares/freertos/source/portable/memmang/heap_4.c ****                         xWantedSize = 0;
 159:middlewares/freertos/source/portable/memmang/heap_4.c ****                     }
 160:middlewares/freertos/source/portable/memmang/heap_4.c ****                 }
 161:middlewares/freertos/source/portable/memmang/heap_4.c ****                 else
 162:middlewares/freertos/source/portable/memmang/heap_4.c ****                 {
 163:middlewares/freertos/source/portable/memmang/heap_4.c ****                     mtCOVERAGE_TEST_MARKER();
 164:middlewares/freertos/source/portable/memmang/heap_4.c ****                 }
 165:middlewares/freertos/source/portable/memmang/heap_4.c ****             }
 166:middlewares/freertos/source/portable/memmang/heap_4.c ****             else
 167:middlewares/freertos/source/portable/memmang/heap_4.c ****             {
 168:middlewares/freertos/source/portable/memmang/heap_4.c ****                 xWantedSize = 0;
 169:middlewares/freertos/source/portable/memmang/heap_4.c ****             }
 170:middlewares/freertos/source/portable/memmang/heap_4.c **** 
 171:middlewares/freertos/source/portable/memmang/heap_4.c ****             if( ( xWantedSize > 0 ) && ( xWantedSize <= xFreeBytesRemaining ) )
 172:middlewares/freertos/source/portable/memmang/heap_4.c ****             {
 173:middlewares/freertos/source/portable/memmang/heap_4.c ****                 /* Traverse the list from the start	(lowest address) block until
 174:middlewares/freertos/source/portable/memmang/heap_4.c ****                  * one of adequate size is found. */
 175:middlewares/freertos/source/portable/memmang/heap_4.c ****                 pxPreviousBlock = &xStart;
 176:middlewares/freertos/source/portable/memmang/heap_4.c ****                 pxBlock = xStart.pxNextFreeBlock;
 177:middlewares/freertos/source/portable/memmang/heap_4.c **** 
 178:middlewares/freertos/source/portable/memmang/heap_4.c ****                 while( ( pxBlock->xBlockSize < xWantedSize ) && ( pxBlock->pxNextFreeBlock != NULL 
 179:middlewares/freertos/source/portable/memmang/heap_4.c ****                 {
 180:middlewares/freertos/source/portable/memmang/heap_4.c ****                     pxPreviousBlock = pxBlock;
 181:middlewares/freertos/source/portable/memmang/heap_4.c ****                     pxBlock = pxBlock->pxNextFreeBlock;
 182:middlewares/freertos/source/portable/memmang/heap_4.c ****                 }
 183:middlewares/freertos/source/portable/memmang/heap_4.c **** 
 184:middlewares/freertos/source/portable/memmang/heap_4.c ****                 /* If the end marker was reached then a block of adequate size
 185:middlewares/freertos/source/portable/memmang/heap_4.c ****                  * was not found. */
 186:middlewares/freertos/source/portable/memmang/heap_4.c ****                 if( pxBlock != pxEnd )
 187:middlewares/freertos/source/portable/memmang/heap_4.c ****                 {
 188:middlewares/freertos/source/portable/memmang/heap_4.c ****                     /* Return the memory space pointed to - jumping over the
 189:middlewares/freertos/source/portable/memmang/heap_4.c ****                      * BlockLink_t structure at its start. */
 190:middlewares/freertos/source/portable/memmang/heap_4.c ****                     pvReturn = ( void * ) ( ( ( uint8_t * ) pxPreviousBlock->pxNextFreeBlock ) + xH
 191:middlewares/freertos/source/portable/memmang/heap_4.c **** 
 192:middlewares/freertos/source/portable/memmang/heap_4.c ****                     /* This block is being returned for use so must be taken out
 193:middlewares/freertos/source/portable/memmang/heap_4.c ****                      * of the list of free blocks. */
 194:middlewares/freertos/source/portable/memmang/heap_4.c ****                     pxPreviousBlock->pxNextFreeBlock = pxBlock->pxNextFreeBlock;
 195:middlewares/freertos/source/portable/memmang/heap_4.c **** 
 196:middlewares/freertos/source/portable/memmang/heap_4.c ****                     /* If the block is larger than required it can be split into
 197:middlewares/freertos/source/portable/memmang/heap_4.c ****                      * two. */
 198:middlewares/freertos/source/portable/memmang/heap_4.c ****                     if( ( pxBlock->xBlockSize - xWantedSize ) > heapMINIMUM_BLOCK_SIZE )
 199:middlewares/freertos/source/portable/memmang/heap_4.c ****                     {
 200:middlewares/freertos/source/portable/memmang/heap_4.c ****                         /* This block is to be split into two.  Create a new
