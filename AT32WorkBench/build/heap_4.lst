  27:middlewares/freertos/source/portable/memmang/heap_4.c **** /*
  28:middlewares/freertos/source/portable/memmang/heap_4.c ****  * A sample implementation of pvPortMalloc() and vPortFree() that combines
  29:middlewares/freertos/source/portable/memmang/heap_4.c ****  * (coalescences) adjacent memory blocks as they are freed, and in so doing
  30:middlewares/freertos/source/portable/memmang/heap_4.c ****  * limits memory fragmentation.
  31:middlewares/freertos/source/portable/memmang/heap_4.c ****  *
