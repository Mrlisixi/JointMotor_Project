  51:middlewares/freertos/source/portable/memmang/heap_4.c **** /* Block sizes must not get too small. */
  52:middlewares/freertos/source/portable/memmang/heap_4.c **** #define heapMINIMUM_BLOCK_SIZE    ( ( size_t ) ( xHeapStructSize << 1 ) )
  53:middlewares/freertos/source/portable/memmang/heap_4.c **** 
