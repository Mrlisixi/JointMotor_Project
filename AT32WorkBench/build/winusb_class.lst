ARM GAS  C:\Users\10963\AppData\Local\Temp\ccHXN6hX.s 			page 4


 145:project/src/winusb_class.c ****   {
 146:project/src/winusb_class.c ****     /* class request */
 147:project/src/winusb_class.c ****     case USB_REQ_TYPE_CLASS:
 148:project/src/winusb_class.c ****       usbd_ctrl_unsupport(pudev);
