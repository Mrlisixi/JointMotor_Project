 159:project/src/winusb_class.c ****           break;
 160:project/src/winusb_class.c ****         case USB_STD_REQ_SET_INTERFACE:
 161:project/src/winusb_class.c ****           p_winusb->alt_setting = setup->wValue;
 162:project/src/winusb_class.c ****           break;
 163:project/src/winusb_class.c ****         case USB_STD_REQ_CLEAR_FEATURE:
 164:project/src/winusb_class.c ****           break;
 165:project/src/winusb_class.c ****         case USB_STD_REQ_SET_FEATURE:
 166:project/src/winusb_class.c ****           break;
 167:project/src/winusb_class.c ****         default:
 168:project/src/winusb_class.c ****           usbd_ctrl_unsupport(pudev);
 169:project/src/winusb_class.c ****           break;
 170:project/src/winusb_class.c ****       }
 171:project/src/winusb_class.c ****       break;
 172:project/src/winusb_class.c **** #if (USBD_SUPPORT_WINUSB == 1)      
 173:project/src/winusb_class.c ****     case USB_REQ_TYPE_VENDOR:
 174:project/src/winusb_class.c ****       if(setup->bRequest == WINUSB_BMS_VENDOR_CODE)
 175:project/src/winusb_class.c ****       {
 176:project/src/winusb_class.c ****         usbd_get_winusb_descriptor(pudev);
 177:project/src/winusb_class.c ****       }
 178:project/src/winusb_class.c ****       else
 179:project/src/winusb_class.c ****       {
 180:project/src/winusb_class.c ****         usbd_ctrl_unsupport(pudev);
 181:project/src/winusb_class.c ****       }
 182:project/src/winusb_class.c ****       break;
 183:project/src/winusb_class.c **** #endif
 184:project/src/winusb_class.c ****     default:
 185:project/src/winusb_class.c ****       usbd_ctrl_unsupport(pudev);
 186:project/src/winusb_class.c ****       break;
 187:project/src/winusb_class.c ****   }
