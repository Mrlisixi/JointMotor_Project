 150:project/src/winusb_class.c ****     /* standard request */
 151:project/src/winusb_class.c ****     case USB_REQ_TYPE_STANDARD:
 152:project/src/winusb_class.c ****       switch(setup->bRequest)
 153:project/src/winusb_class.c ****       {
