 191:project/src/winusb_class.c **** #if (USBD_SUPPORT_WINUSB == 1)
 192:project/src/winusb_class.c **** static usb_sts_type usbd_get_winusb_descriptor(usbd_core_type *udev)
 193:project/src/winusb_class.c **** {
 194:project/src/winusb_class.c **** 	usb_sts_type ret = USB_OK;
 195:project/src/winusb_class.c ****   uint16_t len = 0;
 196:project/src/winusb_class.c ****   usbd_desc_t *desc = NULL;
 197:project/src/winusb_class.c ****   uint8_t desc_type = udev->setup.wIndex;
 198:project/src/winusb_class.c **** 	
 199:project/src/winusb_class.c **** 	switch(desc_type)
 200:project/src/winusb_class.c ****   {
 201:project/src/winusb_class.c **** 		case USB_WINUSB_COMPAT_ID:
ARM GAS  C:\Users\10963\AppData\Local\Temp\ccHXN6hX.s 			page 5


 202:project/src/winusb_class.c **** 			desc = udev->desc_handler->get_device_winusb_os_feature();
 203:project/src/winusb_class.c **** 		  break;
 204:project/src/winusb_class.c **** 		case USB_WINUSB_PROPERTIES_ID:
 205:project/src/winusb_class.c **** 			desc = udev->desc_handler->get_device_winusb_os_property();
 206:project/src/winusb_class.c **** 		  break;
 207:project/src/winusb_class.c **** 		default:
 208:project/src/winusb_class.c ****       usbd_ctrl_unsupport(udev);
 209:project/src/winusb_class.c ****       return ret;
 210:project/src/winusb_class.c **** 	}
 211:project/src/winusb_class.c **** 	if(desc != NULL)
 212:project/src/winusb_class.c ****   {
 213:project/src/winusb_class.c ****     if((desc->length != 0) && (udev->setup.wLength != 0))
 214:project/src/winusb_class.c ****     {
 215:project/src/winusb_class.c ****       len = MIN(desc->length , udev->setup.wLength);
 216:project/src/winusb_class.c ****       usbd_ctrl_send(udev, desc->descriptor, len);
 217:project/src/winusb_class.c ****     }
 218:project/src/winusb_class.c ****   }
 219:project/src/winusb_class.c **** 	
 220:project/src/winusb_class.c **** 	return ret;
 221:project/src/winusb_class.c **** }
 222:project/src/winusb_class.c **** #endif
