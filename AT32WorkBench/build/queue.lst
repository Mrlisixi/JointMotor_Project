 245:middlewares/freertos/source/queue.c **** /*
 246:middlewares/freertos/source/queue.c ****  * Macro to mark a queue as locked.  Locking a queue prevents an ISR from
 247:middlewares/freertos/source/queue.c ****  * accessing the queue event lists.
 248:middlewares/freertos/source/queue.c ****  */
 249:middlewares/freertos/source/queue.c **** #define prvLockQueue( pxQueue )                            \
 250:middlewares/freertos/source/queue.c ****     taskENTER_CRITICAL();                                  \
 251:middlewares/freertos/source/queue.c ****     {                                                      \
 252:middlewares/freertos/source/queue.c ****         if( ( pxQueue )->cRxLock == queueUNLOCKED )        \
 253:middlewares/freertos/source/queue.c ****         {                                                  \
 254:middlewares/freertos/source/queue.c ****             ( pxQueue )->cRxLock = queueLOCKED_UNMODIFIED; \
 255:middlewares/freertos/source/queue.c ****         }                                                  \
