  41:project/src/sysmem.c ****  * #  .data  #  .bss  #       newlib heap       #          msp stack          #
  42:project/src/sysmem.c ****  * #         #        #                         # reserved by _min_stack_size #
  43:project/src/sysmem.c ****  * ############################################################################
