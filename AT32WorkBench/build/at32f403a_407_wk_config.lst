  64:project/src/at32f403a_407_wk_config.c **** /**
  65:project/src/at32f403a_407_wk_config.c ****   * @brief  system clock config program
  66:project/src/at32f403a_407_wk_config.c ****   * @note   the system clock is configured as follow:
  67:project/src/at32f403a_407_wk_config.c ****   *         system clock (sclk)   = hext * pll_mult
  68:project/src/at32f403a_407_wk_config.c ****   *         system clock source   = HEXT_VALUE
  69:project/src/at32f403a_407_wk_config.c ****   *         - hext                = HEXT_VALUE
  70:project/src/at32f403a_407_wk_config.c ****   *         - sclk                = 240000000
  71:project/src/at32f403a_407_wk_config.c ****   *         - ahbdiv              = 1
  72:project/src/at32f403a_407_wk_config.c ****   *         - ahbclk              = 240000000
  73:project/src/at32f403a_407_wk_config.c ****   *         - apb1div             = 2
  74:project/src/at32f403a_407_wk_config.c ****   *         - apb1clk             = 120000000
