 105:libraries/drivers/src/at32f403a_407_usb.c **** /**
 106:libraries/drivers/src/at32f403a_407_usb.c ****   * @brief  mapping usb packet buffer area
 107:libraries/drivers/src/at32f403a_407_usb.c ****   *         two mapping intervals are available for packet buffer area,
 108:libraries/drivers/src/at32f403a_407_usb.c ****   *         and are select by the usbbufs in the crm misc1 register.
 109:libraries/drivers/src/at32f403a_407_usb.c ****   *         when usbbufs is 0,sram size is 512 bytes, packet buffer start
 110:libraries/drivers/src/at32f403a_407_usb.c ****   *         address is 0x40006000.when usbbufs is 1, sram size is fixed to
 111:libraries/drivers/src/at32f403a_407_usb.c ****   *         768~1280 bytes, and the  packet buffer start address is fixed to
 112:libraries/drivers/src/at32f403a_407_usb.c ****   *         0x40007800,packet buffer size decided by whether can1 and can2 are
 113:libraries/drivers/src/at32f403a_407_usb.c ****   *         enabled;when both can1 and can2 are disabled, usb packet buffer can be set to the
 114:libraries/drivers/src/at32f403a_407_usb.c ****   *         maximum of 1280 bytes; when either can1 or can2 is enabled, usb packet buffer can be se
 115:libraries/drivers/src/at32f403a_407_usb.c ****   *         maximum of 1024 bytes; when both CAN1 and CAN2 are enabled, usb packet buffer can be se
 116:libraries/drivers/src/at32f403a_407_usb.c ****   *         maximum of 768 bytes.
 117:libraries/drivers/src/at32f403a_407_usb.c ****   * @param  usbx: to select the usb peripheral.
 118:libraries/drivers/src/at32f403a_407_usb.c ****   *         parameter as following values: USB
 119:libraries/drivers/src/at32f403a_407_usb.c ****   * @retval none
 120:libraries/drivers/src/at32f403a_407_usb.c ****   */
