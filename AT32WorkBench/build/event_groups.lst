  51:middlewares/freertos/source/event_groups.c ****     #define eventCLEAR_EVENTS_ON_EXIT_BIT    0x0100U
  52:middlewares/freertos/source/event_groups.c ****     #define eventUNBLOCKED_DUE_TO_BIT_SET    0x0200U
  53:middlewares/freertos/source/event_groups.c ****     #define eventWAIT_FOR_ALL_BITS           0x0400U
  54:middlewares/freertos/source/event_groups.c ****     #define eventEVENT_BITS_CONTROL_BYTES    0xff00U
  55:middlewares/freertos/source/event_groups.c **** #else
