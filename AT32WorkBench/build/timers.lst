 128:middlewares/freertos/source/timers.c **** /* The list in which active timers are stored.  Timers are referenced in expire
 129:middlewares/freertos/source/timers.c ****  * time order, with the nearest expiry time at the front of the list.  Only the
 130:middlewares/freertos/source/timers.c ****  * timer service task is allowed to access these lists.
 131:middlewares/freertos/source/timers.c ****  * xActiveTimerList1 and xActiveTimerList2 could be at function scope but that
 132:middlewares/freertos/source/timers.c ****  * breaks some kernel aware debuggers, and debuggers that reply on removing the
 133:middlewares/freertos/source/timers.c ****  * static qualifier. */
 134:middlewares/freertos/source/timers.c ****     PRIVILEGED_DATA static List_t xActiveTimerList1;
 135:middlewares/freertos/source/timers.c ****     PRIVILEGED_DATA static List_t xActiveTimerList2;
 136:middlewares/freertos/source/timers.c ****     PRIVILEGED_DATA static List_t * pxCurrentTimerList;
 137:middlewares/freertos/source/timers.c ****     PRIVILEGED_DATA static List_t * pxOverflowTimerList;
 138:middlewares/freertos/source/timers.c **** 
 139:middlewares/freertos/source/timers.c **** /* A queue that is used to send commands to the timer service task. */
