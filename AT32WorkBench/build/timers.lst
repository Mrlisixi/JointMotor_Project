  89:middlewares/freertos/source/timers.c **** /* The definition of messages that can be sent and received on the timer queue.
  90:middlewares/freertos/source/timers.c ****  * Two types of message can be queued - messages that manipulate a software timer,
  91:middlewares/freertos/source/timers.c ****  * and messages that request the execution of a non-timer related callback.  The
  92:middlewares/freertos/source/timers.c ****  * two message types are defined in two separate structures, xTimerParametersType
  93:middlewares/freertos/source/timers.c ****  * and xCallbackParametersType respectively. */
  94:middlewares/freertos/source/timers.c ****     typedef struct tmrTimerParameters
  95:middlewares/freertos/source/timers.c ****     {
  96:middlewares/freertos/source/timers.c ****         TickType_t xMessageValue; /*<< An optional value used by a subset of commands, for example,
  97:middlewares/freertos/source/timers.c ****         Timer_t * pxTimer;        /*<< The timer to which the command will be applied. */
  98:middlewares/freertos/source/timers.c ****     } TimerParameter_t;
  99:middlewares/freertos/source/timers.c **** 
 100:middlewares/freertos/source/timers.c **** 
 101:middlewares/freertos/source/timers.c ****     typedef struct tmrCallbackParameters
 102:middlewares/freertos/source/timers.c ****     {
 103:middlewares/freertos/source/timers.c ****         PendedFunction_t pxCallbackFunction; /* << The callback function to execute. */
 104:middlewares/freertos/source/timers.c ****         void * pvParameter1;                 /* << The value that will be used as the callback func
 105:middlewares/freertos/source/timers.c ****         uint32_t ulParameter2;               /* << The value that will be used as the callback func
 106:middlewares/freertos/source/timers.c ****     } CallbackParameters_t;
 107:middlewares/freertos/source/timers.c **** 
 108:middlewares/freertos/source/timers.c **** /* The structure that contains the two message types, along with an identifier
 109:middlewares/freertos/source/timers.c ****  * that is used to determine which message type is valid. */
 110:middlewares/freertos/source/timers.c ****     typedef struct tmrTimerQueueMessage
 111:middlewares/freertos/source/timers.c ****     {
 112:middlewares/freertos/source/timers.c ****         BaseType_t xMessageID; /*<< The command being sent to the timer service task. */
 113:middlewares/freertos/source/timers.c ****         union
 114:middlewares/freertos/source/timers.c ****         {
 115:middlewares/freertos/source/timers.c ****             TimerParameter_t xTimerParameters;
 116:middlewares/freertos/source/timers.c **** 
 117:middlewares/freertos/source/timers.c ****             /* Don't include xCallbackParameters if it is not going to be used as
 118:middlewares/freertos/source/timers.c ****              * it makes the structure (and therefore the timer queue) larger. */
 119:middlewares/freertos/source/timers.c ****             #if ( INCLUDE_xTimerPendFunctionCall == 1 )
 120:middlewares/freertos/source/timers.c ****                 CallbackParameters_t xCallbackParameters;
 121:middlewares/freertos/source/timers.c ****             #endif /* INCLUDE_xTimerPendFunctionCall */
 122:middlewares/freertos/source/timers.c ****         } u;
 123:middlewares/freertos/source/timers.c ****     } DaemonTaskMessage_t;
 124:middlewares/freertos/source/timers.c **** 
 125:middlewares/freertos/source/timers.c **** /*lint -save -e956 A manual analysis and inspection has been used to determine
 126:middlewares/freertos/source/timers.c ****  * which static variables must be declared volatile. */
