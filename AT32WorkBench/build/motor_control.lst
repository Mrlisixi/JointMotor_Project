 193:../Motor_Control/src/motor_control.c ****       break;
 194:../Motor_Control/src/motor_control.c ****     case COMMUTATION_STATE_2: /* A+ C- */
 195:../Motor_Control/src/motor_control.c ****       /* A+ */
 196:../Motor_Control/src/motor_control.c ****       tmr_output_channel_mode_select(TMR1, TMR_SELECT_CHANNEL_1, TMR_OUTPUT_CONTROL_PWM_MODE_A);
