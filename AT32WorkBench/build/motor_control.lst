  62:../Core/src/motor_control.c **** void motor_control_process(motor_params_t *motor) {
  63:../Core/src/motor_control.c ****     float bus_voltage;
  64:../Core/src/motor_control.c ****     
  65:../Core/src/motor_control.c ****     if (motor == NULL || !motor->initialized) {
  66:../Core/src/motor_control.c ****         return;
  67:../Core/src/motor_control.c ****     }
  68:../Core/src/motor_control.c ****     
  69:../Core/src/motor_control.c ****     cia402_process(&motor->ds402);
  70:../Core/src/motor_control.c ****     motor_monitor_process(motor);
  71:../Core/src/motor_control.c ****     
  72:../Core/src/motor_control.c ****     if (motor_monitor_is_fault_active(motor)) {
  73:../Core/src/motor_control.c ****         motor->state = MOTOR_STATE_FAULT;
  74:../Core/src/motor_control.c ****         motor_control_handle_fault(motor);
  75:../Core/src/motor_control.c ****         return;
  76:../Core/src/motor_control.c ****     }
  77:../Core/src/motor_control.c ****     
  78:../Core/src/motor_control.c ****     switch (motor->state) {
  79:../Core/src/motor_control.c ****         case MOTOR_STATE_INIT:
  80:../Core/src/motor_control.c ****             if (cia402_get_state(&motor->ds402) == CIA402_STATE_OPERATION_ENABLED) {
