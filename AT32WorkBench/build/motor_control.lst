 182:../Motor_Control/src/motor_control.c ****   
 183:../Motor_Control/src/motor_control.c ****   /* set PWM outputs based on commutation state */
 184:../Motor_Control/src/motor_control.c ****   switch(state)
 185:../Motor_Control/src/motor_control.c ****   {
