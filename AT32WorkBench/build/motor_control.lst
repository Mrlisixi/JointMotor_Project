 240:../Motor_Control/src/motor_control.c **** /**
 241:../Motor_Control/src/motor_control.c ****   * @brief  advance to next commutation state
 242:../Motor_Control/src/motor_control.c ****   * @param  motor: motor parameters structure
 243:../Motor_Control/src/motor_control.c ****   * @retval none
 244:../Motor_Control/src/motor_control.c ****   */
 245:../Motor_Control/src/motor_control.c **** static void motor_next_commutation_state(motor_params_t *motor)
 246:../Motor_Control/src/motor_control.c **** {
 247:../Motor_Control/src/motor_control.c ****   if (motor->direction == MOTOR_DIR_CW)
 248:../Motor_Control/src/motor_control.c ****   {
 249:../Motor_Control/src/motor_control.c ****     /* clockwise direction: increment state */
 250:../Motor_Control/src/motor_control.c ****     motor->comm_state = (commutation_state_t)((motor->comm_state + 1) % COMMUTATION_STATE_MAX);
 251:../Motor_Control/src/motor_control.c ****   } else {
 252:../Motor_Control/src/motor_control.c ****     /* counter-clockwise direction: decrement state */
 253:../Motor_Control/src/motor_control.c ****     if (motor->comm_state == 0)
 254:../Motor_Control/src/motor_control.c ****     {
 255:../Motor_Control/src/motor_control.c ****       motor->comm_state = COMMUTATION_STATE_MAX - 1;
 256:../Motor_Control/src/motor_control.c ****     } else {
