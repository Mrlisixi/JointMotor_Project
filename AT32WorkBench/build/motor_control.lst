  81:../Motor_Control/src/motor_control.c ****       motor->last_commutation_time = current_time;
  82:../Motor_Control/src/motor_control.c ****       
  83:../Motor_Control/src/motor_control.c ****       /* advance to next commutation state */
  84:../Motor_Control/src/motor_control.c ****       motor_next_commutation_state(motor);
  85:../Motor_Control/src/motor_control.c ****     }
