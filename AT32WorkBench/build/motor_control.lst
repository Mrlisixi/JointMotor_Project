  67:../Motor_Control/src/motor_control.c **** void motor_control_process(motor_params_t *motor)
  68:../Motor_Control/src/motor_control.c **** {
  69:../Motor_Control/src/motor_control.c ****   uint32_t current_time;
  70:../Motor_Control/src/motor_control.c ****   
  71:../Motor_Control/src/motor_control.c ****   /* process only if motor is running */
  72:../Motor_Control/src/motor_control.c ****   if (motor->state == MOTOR_STATE_RUNNING)
  73:../Motor_Control/src/motor_control.c ****   {
  74:../Motor_Control/src/motor_control.c ****     /* get current time */
  75:../Motor_Control/src/motor_control.c ****     current_time = wk_timebase_get();
  76:../Motor_Control/src/motor_control.c ****     
  77:../Motor_Control/src/motor_control.c ****     /* check if commutation is needed */
  78:../Motor_Control/src/motor_control.c ****     if (current_time - motor->last_commutation_time >= motor->commutation_interval)
  79:../Motor_Control/src/motor_control.c ****     {
