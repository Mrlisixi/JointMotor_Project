 161:middlewares/freertos/source/stream_buffer.c **** /*
 162:middlewares/freertos/source/stream_buffer.c ****  * Add xCount bytes from pucData into the pxStreamBuffer message buffer.
 163:middlewares/freertos/source/stream_buffer.c ****  * Returns the number of bytes written, which will either equal xCount in the
 164:middlewares/freertos/source/stream_buffer.c ****  * success case, or 0 if there was not enough space in the buffer (in which case
 165:middlewares/freertos/source/stream_buffer.c ****  * no data is written into the buffer).
 166:middlewares/freertos/source/stream_buffer.c ****  */
 167:middlewares/freertos/source/stream_buffer.c **** static size_t prvWriteBytesToBuffer( StreamBuffer_t * const pxStreamBuffer,
 168:middlewares/freertos/source/stream_buffer.c ****                                      const uint8_t * pucData,
 169:middlewares/freertos/source/stream_buffer.c ****                                      size_t xCount ) PRIVILEGED_FUNCTION;
 170:middlewares/freertos/source/stream_buffer.c **** 
 171:middlewares/freertos/source/stream_buffer.c **** /*
 172:middlewares/freertos/source/stream_buffer.c ****  * If the stream buffer is being used as a message buffer, then reads an entire
 173:middlewares/freertos/source/stream_buffer.c ****  * message out of the buffer.  If the stream buffer is being used as a stream
 174:middlewares/freertos/source/stream_buffer.c ****  * buffer then read as many bytes as possible from the buffer.
 175:middlewares/freertos/source/stream_buffer.c ****  * prvReadBytesFromBuffer() is called to actually extract the bytes from the
 176:middlewares/freertos/source/stream_buffer.c ****  * buffer's data storage area.
 177:middlewares/freertos/source/stream_buffer.c ****  */
