 181:middlewares/freertos/source/stream_buffer.c ****                                         size_t xBytesAvailable,
 182:middlewares/freertos/source/stream_buffer.c ****                                         size_t xBytesToStoreMessageLength ) PRIVILEGED_FUNCTION;
 183:middlewares/freertos/source/stream_buffer.c **** 
