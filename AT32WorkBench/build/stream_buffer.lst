 227:middlewares/freertos/source/stream_buffer.c ****         /* In case the stream buffer is going to be used as a message buffer
 228:middlewares/freertos/source/stream_buffer.c ****          * (that is, it will hold discrete messages with a little meta data that
 229:middlewares/freertos/source/stream_buffer.c ****          * says how big the next message is) check the buffer will be large enough
 230:middlewares/freertos/source/stream_buffer.c ****          * to hold at least one message. */
 231:middlewares/freertos/source/stream_buffer.c ****         if( xIsMessageBuffer == pdTRUE )
 232:middlewares/freertos/source/stream_buffer.c ****         {
 233:middlewares/freertos/source/stream_buffer.c ****             /* Is a message buffer but not statically allocated. */
