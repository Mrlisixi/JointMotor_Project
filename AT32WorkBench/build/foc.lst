 111:../Motor_Control/src/foc.c ****   
 112:../Motor_Control/src/foc.c ****   /* Limit q-axis current */
 113:../Motor_Control/src/foc.c ****   if (i_q_ref > MOTOR_PEAK_CURRENT)
 114:../Motor_Control/src/foc.c ****     i_q_ref = MOTOR_PEAK_CURRENT;
 115:../Motor_Control/src/foc.c ****   if (i_q_ref < -MOTOR_PEAK_CURRENT)
