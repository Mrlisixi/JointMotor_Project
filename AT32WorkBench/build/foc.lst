 160:../Motor_Control/src/foc.c **** /**
 161:../Motor_Control/src/foc.c ****   * @brief  Clark transform: 3-phase current to alpha-beta
 162:../Motor_Control/src/foc.c ****   * @param  i_a: Phase A current (A)
 163:../Motor_Control/src/foc.c ****   * @param  i_b: Phase B current (A)
 164:../Motor_Control/src/foc.c ****   * @param  i_c: Phase C current (A)
 165:../Motor_Control/src/foc.c ****   * @param  i_alpha: Alpha axis current (A)
 166:../Motor_Control/src/foc.c ****   * @param  i_beta: Beta axis current (A)
 167:../Motor_Control/src/foc.c ****   * @retval none
 168:../Motor_Control/src/foc.c ****   */
 169:../Motor_Control/src/foc.c **** void clark_transform(float i_a, float i_b, float i_c, float *i_alpha, float *i_beta)
 170:../Motor_Control/src/foc.c **** {
 171:../Motor_Control/src/foc.c ****   /* Clark transform assuming balanced 3-phase system (i_a + i_b + i_c = 0) */
 172:../Motor_Control/src/foc.c ****   *i_alpha = i_a;
 173:../Motor_Control/src/foc.c ****   *i_beta = (i_a + 2.0f * i_b) / sqrtf(3.0f);
 174:../Motor_Control/src/foc.c **** }
 175:../Motor_Control/src/foc.c **** 
 176:../Motor_Control/src/foc.c **** /**
 177:../Motor_Control/src/foc.c ****   * @brief  Park transform: alpha-beta to d-q
 178:../Motor_Control/src/foc.c ****   * @param  i_alpha: Alpha axis current (A)
 179:../Motor_Control/src/foc.c ****   * @param  i_beta: Beta axis current (A)
 180:../Motor_Control/src/foc.c ****   * @param  angle: Rotor angle (rad)
 181:../Motor_Control/src/foc.c ****   * @param  i_d: D axis current (A)
 182:../Motor_Control/src/foc.c ****   * @param  i_q: Q axis current (A)
 183:../Motor_Control/src/foc.c ****   * @retval none
 184:../Motor_Control/src/foc.c ****   */
 185:../Motor_Control/src/foc.c **** void park_transform(float i_alpha, float i_beta, float angle, float *i_d, float *i_q)
 186:../Motor_Control/src/foc.c **** {
 187:../Motor_Control/src/foc.c ****   float cos_theta = cosf(angle);
 188:../Motor_Control/src/foc.c ****   float sin_theta = sinf(angle);
 189:../Motor_Control/src/foc.c ****   
 190:../Motor_Control/src/foc.c ****   *i_d = i_alpha * cos_theta + i_beta * sin_theta;
 191:../Motor_Control/src/foc.c ****   *i_q = -i_alpha * sin_theta + i_beta * cos_theta;
 192:../Motor_Control/src/foc.c **** }
 193:../Motor_Control/src/foc.c **** 
 194:../Motor_Control/src/foc.c **** /**
 195:../Motor_Control/src/foc.c ****   * @brief  Inverse Park transform: d-q to alpha-beta
 196:../Motor_Control/src/foc.c ****   * @param  v_d: D axis voltage (V)
 197:../Motor_Control/src/foc.c ****   * @param  v_q: Q axis voltage (V)
 198:../Motor_Control/src/foc.c ****   * @param  angle: Rotor angle (rad)
 199:../Motor_Control/src/foc.c ****   * @param  v_alpha: Alpha axis voltage (V)
 200:../Motor_Control/src/foc.c ****   * @param  v_beta: Beta axis voltage (V)
 201:../Motor_Control/src/foc.c ****   * @retval none
ARM GAS  C:\Users\10963\AppData\Local\Temp\cc3DHeWe.s 			page 5


 202:../Motor_Control/src/foc.c ****   */
 203:../Motor_Control/src/foc.c **** void inverse_park_transform(float v_d, float v_q, float angle, float *v_alpha, float *v_beta)
 204:../Motor_Control/src/foc.c **** {
 205:../Motor_Control/src/foc.c ****   float cos_theta = cosf(angle);
 206:../Motor_Control/src/foc.c ****   float sin_theta = sinf(angle);
 207:../Motor_Control/src/foc.c ****   
 208:../Motor_Control/src/foc.c ****   *v_alpha = v_d * cos_theta - v_q * sin_theta;
 209:../Motor_Control/src/foc.c ****   *v_beta = v_d * sin_theta + v_q * cos_theta;
 210:../Motor_Control/src/foc.c **** }
 211:../Motor_Control/src/foc.c **** 
