 119:../Motor_Control/src/foc.c ****   float i_d_ref = 0.0f;
 120:../Motor_Control/src/foc.c ****   
 121:../Motor_Control/src/foc.c ****   /* Current controllers */
 122:../Motor_Control/src/foc.c ****   foc->i_d_error = i_d_ref - foc->i_d;
 123:../Motor_Control/src/foc.c ****   foc->i_q_error = i_q_ref - foc->i_q;
 124:../Motor_Control/src/foc.c ****   
 125:../Motor_Control/src/foc.c ****   foc->i_d_integral += foc->i_d_error * (1.0f / FOC_CONTROL_FREQUENCY);
 126:../Motor_Control/src/foc.c ****   foc->i_q_integral += foc->i_q_error * (1.0f / FOC_CONTROL_FREQUENCY);
 127:../Motor_Control/src/foc.c ****   
 128:../Motor_Control/src/foc.c ****   /* Limit integral windup */
 129:../Motor_Control/src/foc.c ****   if (foc->i_d_integral > 10.0f)
 130:../Motor_Control/src/foc.c ****     foc->i_d_integral = 10.0f;
